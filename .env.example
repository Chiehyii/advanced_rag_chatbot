# ============================================================
# CREDENTIAL ROTATION CHECKLIST
# If any value from your .env was ever exposed, rotate it:
#
#  [ ] OpenAI API Key  → platform.openai.com → API keys → Revoke & create new
#  [ ] Zilliz API Key  → cloud.zilliz.com → API Keys → Revoke & create new
#  [ ] PostgreSQL password → ALTER USER <user> PASSWORD '<new_pw>';
#  [ ] LINE Channel Secret/Token → developers.line.biz → revoke & reissue
#  [ ] JWT_SECRET_KEY  → generate: python -c "import secrets; print(secrets.token_hex(32))"
#
# NEVER commit .env — only commit this .env.example file.
# ============================================================

# --- LLM api ---
OPENAI_API_KEY=""
OPENAI_MODEL_NAME=""
EMBEDDING_MODEL=""

# --- Authentication ---
ADMIN_USERNAME=""
# Generate hash: python scripts/generate_hash.py
ADMIN_PASSWORD_HASH=''

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 64 hex characters (256 bits of entropy)
JWT_SECRET_KEY=""

# --- Vector DB (Zilliz / Milvus) ---
ZILLIZ_API_KEY=""
MILVUS_COLLECTION=""
CLUSTER_ENDPOINT=""

# --- PostgreSQL ---
DB_HOST=""
DB_PORT="5432"
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_TABLE_NAME=""
DATABASE_URL=""
DB_POOL_MINCONN="1"
DB_POOL_MAXCONN="10"

# --- LINE Messaging API ---
LINE_CHANNEL_SECRET=""
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_USER_ID=""

# --- Rate Limiting ---
RATE_LIMIT_CHAT="10/minute"
RATE_LIMIT_FEEDBACK="20/minute"
# Optional shared rate-limit backend for multi-worker deployments.
# Example: "redis://default:<password>@<host>:6379/0"
RATE_LIMIT_STORAGE_URI=""
# Set true only when the app is reachable exclusively through a trusted reverse proxy.
TRUST_PROXY_HEADERS="false"

# --- Request Limits ---
MAX_REQUEST_BODY_BYTES="1048576"

# --- Scraper SSL fallback ---
# Comma-separated host allowlist for retrying legacy HTTPS sites after normal SSL verification fails.
# Leading dot allows subdomains, e.g. ".tcu.edu.tw" matches "yizhu.tcu.edu.tw".
SSL_FALLBACK_ALLOWED_HOSTS=".tcu.edu.tw,www.nstc.gov.tw"

# Scheduler AI extraction output limits.
EXTRACTION_MAX_COMPLETION_TOKENS="4000"
EXTRACTION_RETRY_MAX_COMPLETION_TOKENS="6000"
CHECKPOINT_RETENTION_DAYS="7"
QA_LOG_RETENTION_DAYS="90"
CHECKPOINT_CLEANUP_INTERVAL_HOURS="24"
SCHEDULER_LOCKS_ENABLED="true"
# Set false when running scheduler as a separate worker/cron service.
ENABLE_WEB_SCHEDULER="true"
# For a standalone scheduler service, set SCHEDULER_WORKER="true" and run:
# python scheduler.py
SCHEDULER_WORKER="false"

# --- CORS (no trailing slash on origins) ---
# Example: "http://localhost:8000,https://yourdomain.com"
CORS_ALLOWED_ORIGINS=""
